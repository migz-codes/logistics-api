{
  "name": "nest-template",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/src/main.js",
    "lint": "biome lint && tsc --noEmit",
    "format": "biome check --fix --unsafe",
    "prisma:push": "prisma db push",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name",
    "prisma:reset": "prisma migrate reset",
    "docker:test": "docker-compose build --no-cache && docker-compose up",
    "graphql:types": "graphql-codegen",
    "generate:types": "bun run prisma:generate && bun run graphql:types"
  },
  "dependencies": {
    "@apollo/server": "4.11.0",
    "@graphql-codegen/cli": "6.2.1",
    "@graphql-codegen/typescript": "5.0.9",
    "@nestjs/apollo": "12.2.0",
    "@nestjs/common": "10.0.0",
    "@nestjs/config": "3.0.0",
    "@nestjs/core": "10.0.0",
    "@nestjs/graphql": "12.2.0",
    "@nestjs/jwt": "11.0.2",
    "@nestjs/platform-express": "10.0.0",
    "@nestjs/schedule": "6.1.1",
    "@prisma/client": "7.4.1",
    "@radix-ui/react-tooltip": "1.2.8",
    "bcrypt": "6.0.0",
    "dotenv": "17.3.1",
    "graphql": "16.9.0",
    "reflect-metadata": "0.2.0",
    "rxjs": "7.8.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "@nestjs/cli": "10.0.0",
    "@nestjs/schematics": "10.0.0",
    "@nestjs/testing": "10.0.0",
    "@types/bcrypt": "6.0.0",
    "@types/express": "5.0.0",
    "@types/jest": "29.5.2",
    "@types/multer": "2.1.0",
    "@types/node": "20.3.1",
    "@types/supertest": "6.0.0",
    "@typescript-eslint/eslint-plugin": "8.0.0",
    "@typescript-eslint/parser": "8.0.0",
    "jest": "29.5.0",
    "prisma": "7.4.1",
    "source-map-support": "0.5.21",
    "supertest": "7.0.0",
    "ts-jest": "29.1.0",
    "ts-loader": "9.4.3",
    "ts-node": "10.9.1",
    "tsconfig-paths": "4.2.0",
    "typescript": "5.1.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      ".+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
