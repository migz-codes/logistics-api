generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         String      @id @default(cuid())
  name       String
  email      String      @unique
  password   String
  updated_at DateTime @updatedAt
  created_at DateTime @default(now())

  warehouses Warehouse[]
}

model Warehouse {
  id             String   @id @default(uuid())
  title          String
  description    String
  city           String
  state          String
  category       String
  area           String
  status         String
  price          String
  address        String
  zip_code       String
  country        String
  updated_at     DateTime @updatedAt
  created_at     DateTime @default(now())

  accountable    User     @relation(fields: [accountable_id], references: [id])
  accountable_id String
}