generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  INVESTOR
  INVESTOR_ADMIN
  ADMIN
}

model User {
  id         String      @id @default(uuid())
  name       String
  email      String      @unique
  password   String
  updated_at DateTime    @updatedAt
  created_at DateTime    @default(now())
  role       Role        @default(ADMIN)

  warehouses     Warehouse[]
  refresh_tokens RefreshToken[]
  companies      Company[] @relation("CompanyOwner")
  member_of      Company[] @relation("CompanyMember")
}

model RefreshToken {
  id         String   @id @default(uuid())
  expires_at DateTime
  created_at DateTime @default(now())

  user_id String
  user    User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model Company {
  id         String   @id @default(uuid())
  name       String
  logo       String?
  updated_at DateTime @updatedAt
  created_at DateTime @default(now())

  owner      User       @relation("CompanyOwner", fields: [owner_id], references: [id])
  owner_id   String
  
  members    User[]     @relation("CompanyMember")
  warehouses Warehouse[]
}

model Warehouse {
  id             String   @id @default(uuid())
  title          String
  description    String
  city           String
  state          String
  category       String
  area           String
  status         String
  price          String
  address        String
  zip_code       String
  country        String
  updated_at     DateTime @updatedAt
  created_at     DateTime @default(now())

  accountable    User     @relation(fields: [accountable_id], references: [id])
  accountable_id String

  company        Company  @relation(fields: [company_id], references: [id])
  company_id     String
}